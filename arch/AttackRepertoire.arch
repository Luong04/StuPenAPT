System AttackRepertoire {
    Component {
        name = "AttackSteps"
        Interface {
            name = "ssh_bruteforce"
            Property {
                name = "MitreAttck"
                value = "T1110"
            }
        }
        Interface {
            name = "service_scan"
            Property {
                name = "MitreAttck" 
                value = "T1046"
            }
        }
    }
    
    Component {
        name = "AttackPatterns"
        Interface {
            name = "network_credential_attack"
