            }
            Property {
                name = "RequiredPrivileges"
                value = "None"
            }
            Property {
                name = "UserInteraction"
                value = "None"
            }
            Property {
                name = "RunningTime"
                value = "Short"
            }
            Property {
                name = "Steps"
                value = "[service_scan, ssh_bruteforce]"
            }
        }
    }
}